---
import PageLayout from '@/layouts/CommonPage.astro'

const headings = [
  { depth: 2, slug: 'about-me', text: 'About Me' },
  { depth: 2, slug: 'about-blog', text: 'About Blog' }
]
---

<PageLayout title='About' {headings} info='/about'>
  <h2 id='about-me'>About Me</h2>
  <p>
    Hi, this is YinFeng.
  </p>
  <p>
    This page is currently kept intentionally simple. The site has just been migrated from an older
    WordPress setup to Astro, and a fuller English profile can be added later.
  </p>

  <h2 id='about-blog'>About Blog</h2>
  <p>
    This blog mainly records AI, agent systems, engineering notes, and learning in progress.
  </p>
  <p>
    Template-author content has been taken offline, and the current version keeps only the pages and
    posts needed for this site.
  </p>
</PageLayout>
